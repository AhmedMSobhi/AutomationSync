# ── Odoo ──────────────────────────────────────────────────
# App root only (…/odoo) — do not append /web or /odoo/sales here
ODOO_URL=https://platraw-staging-31767742.dev.odoo.com/odoo
ODOO_EMAIL=admin
ODOO_PASSWORD=123456
ODOO_TEST_CUSTOMER_SEARCH=mawa
ODOO_TEST_CUSTOMER=mawada

# Order lines — edit .env only; specs call buildOdooTestOrderLines() (no product names in code)
#
# Option A: numbered lines (uncomment / add _2, _3, _4 … as needed)
ODOO_TEST_PRODUCT=Auskobe Beef
ODOO_TEST_PRODUCT_SEARCH=Auskobe
ODOO_TEST_PRODUCT_QTY=1
# ODOO_TEST_PRODUCT_2=Classic Lamb Leg Bone-In Australian
# ODOO_TEST_PRODUCT_2_SEARCH=Lamb
# ODOO_TEST_PRODUCT_2_QTY=2.25
# ODOO_TEST_PRODUCT_3=Third product exact Odoo label
# ODOO_TEST_PRODUCT_3_SEARCH=short search text
# ODOO_TEST_PRODUCT_3_QTY=1
# Optional: use only first N lines when more are defined
# ODOO_TEST_ORDER_LINE_COUNT=2

# Option B: JSON (single line — overrides numbered vars when set)
# ODOO_TEST_ORDER_LINES=[{"product":"Auskobe Beef","search":"Auskobe","quantity":1},{"product":"Classic Lamb Leg Bone-In Australian","search":"Lamb","quantity":2.25}]

ODOO_CONFIRM_WAIT_MS=3000          # wait before Confirm (line totals / UI)

# Post-create update (DEBUG-UPDATE-QTY) — defaults: 3, 0.5, 12.36
# ODOO_TEST_PRODUCT_QTY_UPDATE=3
# ODOO_TEST_PRODUCT_2_QTY_UPDATE=0.5
# ODOO_TEST_PRODUCT_3_QTY_UPDATE=12.36
SYNC_UPDATE_WAIT_MS=30000       # after qty update + confirm (create still uses SYNC_DB_WAIT_MS)

# Delivery pick done-qty (defaults = post-SO update: 3, 0.5, 12.36)
# ODOO_TEST_PRODUCT_QTY_UPDATE=3
# ODOO_DELIVERY_TRANSFER_TYPES=WH/PICK,WH/OUT   # PICK from list (Waiting), OUT via Next Transfer
# ODOO_NEXT_TRANSFER_WAIT_MS=10000              # wait after PICK validate before Next Transfer
# ODOO_INSPECT_ORDER_ID=55665     # for npm run test:step1:delivery-picks only

# ── Medusa Admin ───────────────────────────────────────────
# App base or deep link — helpers normalize to …/app
MEDUSA_ADMIN_URL=https://platraw-test-373575790277.europe-west1.run.app/app
MEDUSA_ADMIN_EMAIL=admin@test.com
MEDUSA_ADMIN_PASSWORD=supersecret

# ── GCP Cloud SQL (run start-cloud-sql-proxy.bat, then connect pgAdmin) ──
# DATABASE_HOST=127.0.0.1
# DATABASE_PORT=5433
# DATABASE_USER=admin
# DATABASE_PASSWORD=your_password
# DATABASE_NAME=dbtest
# DATABASE_URL=postgresql://admin:PASSWORD@127.0.0.1:5433/dbtest
# CLOUD_SQL_INSTANCE=platraw:europe-west1:xlabs-platraw-db-postgres-testing
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\platraw-key.json

# ── Sync ──────────────────────────────────────────────────
SYNC_WAIT_MS=6000
SYNC_DB_WAIT_MS=60000           # 1 min before DB query
SYNC_DB_POLL_TIMEOUT_MS=60000
SYNC_DB_POLL_INTERVAL_MS=5000
SYNC_PAYMENT_WAIT_MS=30000        # after Create Payment, before order_transaction query
SYNC_PAYMENT_POLL_TIMEOUT_MS=60000
SYNC_PAYMENT_POLL_INTERVAL_MS=5000
ORDER_TRANSACTION_REFERENCE=capture
SYNC_FULFILLMENT_WAIT_MS=30000
SYNC_FULFILLMENT_POLL_TIMEOUT_MS=60000
ORDER_FULFILLMENT_REQUIRED_DELETED_AT_DISTINCT=2
AMOUNT_TOLERANCE=0.01              # max allowed diff between Odoo and DB totals (SAR)
FREE_SHIPPING_THRESHOLD=400     # SAR incl. VAT
STANDARD_SHIPPING_FEE=25        # SAR excl. VAT
